cc_binary {
    name: "android.hardware.simplebutton-service",
    relative_install_path: "hw",
    vendor: true,
    init_rc: ["simplebutton.rc"],
    vintf_fragments: ["manifest.xml"],
    srcs: [
        "SimpleButton.cpp",
        "service.cpp",
    ],
    shared_libs: [
        "liblog",
        "libutils",
        "libbinder_ndk",
        "libbase",
    ],
    static_libs: [
        "android.hardware.simplebutton-V1-ndk",
    ],
}
